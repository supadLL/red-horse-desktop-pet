{
  "name": "red-horse-desktop-pet",
  "version": "0.1.0",
  "description": "Cute red Akhal-Teke desktop pet built with Electron, Vite, and TypeScript.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5397 && npm run start:electron\"",
    "start:electron": "node scripts/start-electron.cjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.local.redhorsedesktoppet",
    "productName": "\u5c0f\u8d64\u5f71\u684c\u5ba0",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**",
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts/keyboard-hook.ps1",
        "to": "scripts/keyboard-hook.ps1"
      }
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "icon": "assets/app-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  }
}
